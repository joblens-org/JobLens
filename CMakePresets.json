{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "rpm-system-deps",
      "displayName": "CI/RPM 系统依赖 (不打包 .so)",
      "description": "CI 构建预设。动态库全部由系统 RPM 包管理器提供，RPM Requires 完整声明依赖",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_INSTALL_PREFIX": "/usr",
        "JOBLENS_BUNDLE_LIBS": "OFF"
      }
    },
    {
      "name": "dev-linux",
      "displayName": "本地开发 (RelWithDebInfo)",
      "description": "本地开发构建，前缀 /usr/local",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_INSTALL_PREFIX": "/usr/local",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "rpm-static-epel",
      "displayName": "RPM 自包含 (离线部署)",
      "description": "打包所有 .so + 静态链接 EPEL 库，RPATH 环境隔离，适合无网络环境安装",
      "inherits": "rpm-system-deps",
      "cacheVariables": {
        "JOBLENS_BUNDLE_LIBS": "ON",
        "JOBLENS_STATIC_EPEL": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "rpm-system-deps",
      "configurePreset": "rpm-system-deps"
    },
    {
      "name": "dev-linux",
      "configurePreset": "dev-linux"
    },
    {
      "name": "rpm-static-epel",
      "configurePreset": "rpm-static-epel"
    }
  ],
  "packagePresets": [
    {
      "name": "rpm-system-deps",
      "configurePreset": "rpm-system-deps",
      "generators": ["TGZ", "RPM"],
      "description": "CI 打包：TGZ + RPM，不捆绑 .so"
    },
    {
      "name": "rpm-static-epel",
      "configurePreset": "rpm-static-epel",
      "generators": ["RPM"],
      "description": "自包含 RPM 包，捆绑 .so + RPATH 隔离，无网络可安装"
    }
  ]
}
