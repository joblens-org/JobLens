/*================ 输出适配 ================*/
CollectDataParseFunc __YOUR_COLLECTOR_NAME__Collector::get_writer_parser(
    const std::string& writer_type) {
    using nlohmann::json;

    if (writer_type == "ESWriter") {
        return [](std::any data)->std::any {
            json root;
            root["process_data"] = json::array();
            if (!data.has_value()) return root;

            auto vec = std::any_cast<std::vector<__YOUR_COLLECTOR_NAME__Data>>(data);
            for (const auto& v : vec) {
                json j;
                j["pid"]   = v.pid;
                j["value"] = v.value;
                root["process_data"].push_back(j);
            }
            return root;
        };
    }
    return nullptr;   // 不支持的 writer
}