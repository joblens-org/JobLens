bool __YOUR_COLLECTOR_NAME__Collector::init(const nlohmann::json& cfg) {
    if (cfg.contains("freq")) freq_ = cfg["freq"].get<double>();
    if (cfg.contains("summary") && cfg["summary"].get<std::string>() == "true")
        summary_ = true;
    spdlog::info("__YOUR_COLLECTOR_NAME__Collector init ok");
    return true;
}

